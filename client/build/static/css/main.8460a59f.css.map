.singleMovie{
  background: #181818;
  border-radius: 14px;
  padding: 20px;
  max-width: 240px;
  margin: 0 auto;
  text-align: center;
  box-shadow: 0 6px 16px rgba(0,0,0,.45);
  transition: all 0.3s ease;
}

.singleMovie:hover{
  background: #282828;
}

/* Center movie titles above posters */
.singleMovie h2,
.singleMovie h3{
  color: white;
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 16px;
  text-align: center;
  min-height: 52px; /* keeps cards aligned */
}

.singleMovie p{
  color: #b3b3b3;
  margin-top: 10px;
  font-size: .95rem;
}

img{
  width: 200px;
  height: 300px;
  object-fit: cover;
  border-radius: 10px;
  display: block;
  margin: 0 auto;
  box-shadow: 0 8px 18px rgba(0,0,0,.55);
}

/* Spotify-style button */
.playlistButton{
  margin-top: 18px;
  padding: 10px 18px;
  border: none;
  border-radius: 999px;
  background: #1db954;
  color: white;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.25s ease;
}

.playlistButton:hover{
  background: #1ed760;

}

