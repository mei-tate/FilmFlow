/* Playlist container */
.listOfSong {
  margin: 0 auto;
  max-width: 420px;
  text-align: left;
  font-size: 14px;
  background: #121212;
  padding: 16px;
  border-radius: 12px;
}

/* Remove default list styling */
ul {
  padding: 0;
  margin: 0;
  list-style: none;
}

/* Song item (ONLY styling used now) */
.song-item {
  margin-bottom: 4px;
  padding: 10px 12px;
  border-radius: 6px;

  display: flex;
  flex-direction: column;

  font-family: 'Helvetica Neue', Arial, sans-serif;

  transition: background 0.2s ease;
  cursor: default;
}

/* Hover effect */
.song-item:hover {
  background: #282828;
}

/* Song title */
.song-title {
  font-size: 14px;
  color: #ffffff;
  font-weight: 500;
}

/* Artist */
.song-artist {
  font-size: 12px;
  color: #b3b3b3;
  margin-top: 2px;
}

/* Empty state */
.noPlaylist {
  font-family: 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: #b3b3b3;
  text-align: center;
  padding: 12px;
}

